---
import StatusChip from "./StatusChip.astro";
import type { TeamSummary } from "../schemas";
import { formatDelta, formatRecord, formatScore, formatUpdatedAt, teamHref } from "../lib/format";

interface Props {
  team: TeamSummary;
}

const { team } = Astro.props;
const href = teamHref(team);
---

<article
  class="team-card"
  data-team-id={team.teamId}
  data-tank-score={formatScore(team.tankScore)}
  data-confidence={team.confidence}
  data-conference={team.identity.conference}
  data-state={team.competitiveState}
  data-delta={team.scoreDelta7d === "unknown" ? "unknown" : String(team.scoreDelta7d)}
  data-wins={String(team.record.wins)}
  data-losses={String(team.record.losses)}
  data-form={team.recentForm?.last10Wins === null || team.recentForm?.last10Wins === undefined
    ? "unknown"
    : String(team.recentForm.last10Wins)}
>
  <a class="team-card__link" href={href}>
    <header class="team-card__header">
      <div>
        <p class="team-card__abbr">{team.identity.abbreviation}</p>
        <h2 class="team-card__name">{team.identity.name}</h2>
      </div>
      <p class="team-card__record">
        <span class="visually-hidden">Record </span>{formatRecord(team)}
      </p>
    </header>

    <p class="team-card__state">{team.competitiveState}</p>

    <div class="team-card__scores" aria-label="Scores">
      <StatusChip
        label="Tank Score"
        value={formatScore(team.tankScore)}
        kind="tank"
        band={team.scoreBand}
      />
      <StatusChip label="Team strength" value={formatScore(team.teamStrength)} kind="strength" />
      <StatusChip label="Confidence" value={team.confidence} kind="confidence" />
    </div>

    <p class="team-card__meta">
      <span>{formatDelta(team.scoreDelta7d)}</span>
      <span>Updated {formatUpdatedAt(team.updatedAt)}</span>
    </p>

    <p class="team-card__summary">{team.summary}</p>
  </a>
</article>

<style>
  .team-card {
    min-width: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
  }

  .team-card__link {
    display: block;
    height: 100%;
    padding: var(--space-4);
    color: inherit;
    text-decoration: none;
  }

  .team-card__link:hover .team-card__name {
    color: var(--color-accent);
  }

  .team-card__header {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    align-items: flex-start;
    margin-bottom: var(--space-2);
  }

  .team-card__abbr {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .team-card__name {
    margin: 0.15rem 0 0;
    font-size: 1.2rem;
    line-height: 1.15;
  }

  .team-card__record {
    margin: 0;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .team-card__state {
    margin: 0 0 var(--space-3);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .team-card__scores {
    display: grid;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .team-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    margin: 0 0 var(--space-3);
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .team-card__summary {
    margin: 0;
    font-size: 0.92rem;
    color: var(--color-text-secondary);
    line-height: 1.45;
  }

  @media (min-width: 720px) {
    .team-card__scores {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
