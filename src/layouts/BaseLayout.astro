---
import "../styles/tokens.css";
import { METHODOLOGY } from "../../content/methodology";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Bad, rebuilding, or actually tanking? Evidence-backed NBA competitive outlook.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="att-methodology-version" content={METHODOLOGY.version} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=Source+Serif+4:opsz,wght@8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div id="main" tabindex="-1">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    color-scheme: light;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: var(--font-sans);
    color: var(--color-text);
    background:
      radial-gradient(ellipse at top left, rgba(11, 79, 66, 0.07), transparent 42%),
      linear-gradient(180deg, #e4dfd2 0%, var(--color-bg) 38%, #e4e8e2 100%);
    line-height: 1.5;
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-display);
    font-weight: 700;
  }

  a {
    color: var(--color-accent);
  }

  a:focus-visible,
  button:focus-visible,
  select:focus-visible,
  input:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 100;
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-elevated);
    color: var(--color-text);
  }

  .skip-link:focus {
    left: var(--space-3);
    top: var(--space-3);
  }

  #main:focus {
    outline: none;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
