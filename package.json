{
  "name": "are-they-tanking",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Evidence-backed NBA tracker distinguishing weak teams, rebuilding teams, and tanking signals.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:data": "tsx scripts/validate-data.ts",
    "generate:seed": "tsx scripts/generate-seed.ts",
    "generate:public": "tsx scripts/generate-public.ts",
    "ingest:core": "tsx scripts/ingest-core.ts",
    "ingest:yunoball": "tsx scripts/ingest-yunoball.ts",
    "pipeline": "npm run ingest:core && npm run ingest:yunoball && npm run generate:public && npm run validate:data && npm run build",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run validate:data && npm run build && npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "astro": "^7.1.0",
    "typescript": "~5.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.23.1",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
